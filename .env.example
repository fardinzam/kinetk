# ─── Supabase Project ─────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side only — never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database ─────────────────────────────────────────────────────────────────
# Pooled connection string (Transaction mode, port 6543)
# Supabase Dashboard → Project Settings → Database → Connection pooling
# Local dev (Supabase CLI): postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte key encoded as base64. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY_BASE64=your-32-byte-base64-key

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Used to send workspace invitation emails.
# Get your API key at resend.com
RESEND_API_KEY=re_your_api_key

# ─── App URL ──────────────────────────────────────────────────────────────────
# Public-facing URL — used to construct webhook trigger URLs.
# Production: your Vercel deployment URL. Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
